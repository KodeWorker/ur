# Copy this file to .env and fill in your values

# Required: Gemini API key
GEMINI_API_KEY=

# Optional: override the default model
# UR_MODEL=gemini/gemini-2.5-flash-lite

# Optional: override the data directory
# UR_DATA_DIR=/path/to/data

# Optional: max iterations for the agent loop
# UR_MAX_ITERATIONS=20

# Ollama: URL of your hosted Ollama server (default: localhost)
# UR_OLLAMA_BASE_URL=http://my-server:11434
# Then set the model to use it:
# UR_MODEL=ollama/qwen3:30b

# Tool built-in
# TOOL_BUILTIN_TRUNCATE_AT=4000
# TOOL_BUILTIN_MAX_LINES=200
